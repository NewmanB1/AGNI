{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "portal/src/routes/**/+*.{js,ts,svelte,jsm,server.js,server.ts}",
    "portal/src/hooks.{js,ts,server.js,server.ts}",
    "portal/src/app.html",
    "player.js",
    "src/runtime/ui/player.js",
    "src/runtime/integrity/integrity.js",
    "src/runtime/telemetry/checkpoint.js",
    "src/runtime/ui/frustration.js",
    "src/runtime/telemetry/completion.js",
    "src/runtime/rendering/gate-renderer.js",
    "src/runtime/ui/a11y.js",
    "src/runtime/ui/factory-loader.js",
    "src/runtime/sensors/sensor-bridge.js",
    "src/runtime/rendering/math-renderer.js",
    "src/runtime/telemetry/telemetry.js",
    "src/runtime/sensors/threshold-evaluator.js",
    "src/runtime/rendering/svg-stage.js",
    "src/runtime/rendering/svg-registry.js",
    "src/runtime/rendering/svg-factories.js",
    "src/runtime/rendering/svg-factories-dynamic.js",
    "src/runtime/rendering/svg-factories-geometry.js",
    "src/runtime/rendering/table-renderer.js",
    "src/compiler/build-lesson-ir.js",
    "src/cli.js"
  ],
  "project": [
    "portal/src/**/*.{js,ts,svelte,jsm}",
    "src/**/*.{js,ts}",
    "server/**/*.{js}",
    "hub-tools/**/*.{js}",
    "!portal/.svelte-kit/**",
    "!**/*.d.ts",
    "!**/*.test.{js,ts}"
  ],
  "ignoreFiles": [
    "portal/.svelte-kit/**",
    "**/sw.js",
    "**/service-worker.js",
    "server/sw.js",
    "src/runtime/rendering/svg-factories*.js",
    "src/runtime/rendering/svg-registry.js",
    "src/runtime/rendering/table-renderer.js"
  ],
  "ignoreDependencies": [
    "ajv-formats",
    "remark-rehype",
    "rehype-katex",
    "rehype-stringify"
  ],
  "rules": {
    "files": "error",
    "dependencies": "warn",
    "unlisted": "warn"
  }
}
