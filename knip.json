{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "portal/src/routes/**/+*.{js,ts,svelte,jsm,server.js,server.ts}",
    "portal/src/hooks.{js,ts,server.js,server.ts}",
    "portal/src/app.html",
    "player.js",
    "src/runtime/player.js",
    "src/runtime/integrity.js",
    "src/runtime/checkpoint.js",
    "src/runtime/frustration.js",
    "src/runtime/completion.js",
    "src/runtime/gate-renderer.js",
    "src/runtime/a11y.js",
    "src/runtime/factory-loader.js",
    "src/runtime/sensor-bridge.js",
    "src/runtime/math-renderer.js",
    "src/runtime/telemetry.js",
    "src/runtime/threshold-evaluator.js",
    "src/runtime/svg-stage.js",
    "src/runtime/svg-registry.js",
    "src/runtime/svg-factories.js",
    "src/runtime/svg-factories-dynamic.js",
    "src/runtime/svg-factories-geometry.js",
    "src/runtime/table-renderer.js",
    "src/compiler/buildLessonIR.js",
    "src/engine/index.ts",
    "src/cli.js"
  ],
  "project": [
    "portal/src/**/*.{js,ts,svelte,jsm}",
    "src/**/*.{js,ts}",
    "server/**/*.{js}",
    "hub-tools/**/*.{js}",
    "!portal/.svelte-kit/**",
    "!**/*.d.ts",
    "!**/*.test.{js,ts}"
  ],
  "ignoreFiles": [
    "portal/.svelte-kit/**",
    "**/sw.js",
    "**/service-worker.js",
    "server/sw.js",
    "server/pwa/sw.js",
    "server/pwa/shared.js",
    "src/runtime/sw.js",
    "src/runtime/svg-factories*.js",
    "src/runtime/svg-registry.js",
    "src/runtime/table-renderer.js"
  ],
  "ignoreDependencies": [
    "remark-html",
    "ajv-formats",
    "remark-rehype",
    "rehype-katex",
    "rehype-stringify"
  ],
  "rules": {
    "files": "error",
    "dependencies": "warn",
    "unlisted": "warn"
  }
}
