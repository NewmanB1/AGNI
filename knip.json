{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    // Portal/SvelteKit main anchors (adjust if configs are portal/svelte.config.js etc.)
    "portal/src/routes/**/+*.{js,ts,svelte,jsm,server.js,server.ts}",
    "portal/src/hooks.{js,ts,server.js,server.ts}",
    "portal/src/params/**/*.{js,ts}",
    "portal/src/app.html",
    // Protect core runtime entry points
    "player.js",
    "src/runtime/player.js",
    "src/runtime/factory-loader.js",
    "src/runtime/sensor-bridge.js"
  ],
  "project": [
    // Scan these for usage / dead code inside
    "portal/src/**/*.{js,ts,svelte,jsm}",
    "src/**/*.{js,ts}",
    "server/**/*.{js,ts}",
    "hub-tools/**/*.{js}",
    "!portal/.svelte-kit/**",
    "!**/*.d.ts",
    "!**/*.test.{js,ts}"
  ],
  "ignoreFiles": [
    // Hide false positives: generated + dynamic refs
    "portal/.svelte-kit/**",
    "**/sw.js",
    "**/service-worker.js",
    "server/pwa/sw.js",
    "server/pwa/shared.js",
    "src/runtime/sw.js"
  ],
  "rules": {
    "files": "error",
    "dependencies": "warn",
    "unlisted": "warn"
  }
}
