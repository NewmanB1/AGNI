{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "portal/js/main.js",
    "portal/index.html",
    "player.js",
    "packages/agni-runtime/ui/player.js",
    "packages/agni-runtime/integrity/integrity.js",
    "packages/agni-runtime/telemetry/checkpoint.js",
    "packages/agni-runtime/ui/frustration.js",
    "packages/agni-runtime/telemetry/completion.js",
    "packages/agni-runtime/rendering/gate-renderer.js",
    "packages/agni-runtime/ui/a11y.js",
    "packages/agni-runtime/ui/factory-loader.js",
    "packages/agni-runtime/sensors/sensor-bridge.js",
    "packages/agni-runtime/rendering/math-renderer.js",
    "packages/agni-runtime/telemetry/telemetry.js",
    "packages/agni-runtime/sensors/threshold-evaluator.js",
    "packages/agni-runtime/rendering/svg-stage.js",
    "packages/agni-runtime/rendering/svg-registry.js",
    "packages/agni-runtime/rendering/svg-factories.js",
    "packages/agni-runtime/rendering/svg-factories-dynamic.js",
    "packages/agni-runtime/rendering/svg-factories-geometry.js",
    "packages/agni-runtime/rendering/table-renderer.js",
    "packages/ols-compiler/compiler/build-lesson-ir.js",
    "packages/agni-cli/cli.js"
  ],
  "project": [
    "portal/**/*.{js,html}",
    "server/**/*.{js}",
    "hub-tools/**/*.{js}",
    "packages/**/*.{js,ts}",
    "!**/*.d.ts",
    "!**/*.test.{js,ts}"
  ],
  "ignoreFiles": [
    "**/sw.js",
    "**/service-worker.js",
    "server/sw.js",
    "packages/agni-runtime/rendering/svg-factories*.js",
    "packages/agni-runtime/rendering/svg-registry.js",
    "packages/agni-runtime/rendering/table-renderer.js"
  ],
  "ignoreDependencies": [
    "ajv-formats",
    "remark-rehype",
    "rehype-katex",
    "rehype-stringify"
  ],
  "rules": {
    "files": "error",
    "dependencies": "warn",
    "unlisted": "warn"
  }
}
