# AGNI Hub Environment Configuration
# Copy this file to .env and fill in values for your deployment.
# See docs/ONBOARDING-CONCEPTS.md for detailed descriptions.

# ── Data & File Paths ────────────────────────────────────────────────────────
# AGNI_DATA_DIR=./data
# AGNI_YAML_DIR=./data/yaml
# AGNI_FACTORY_DIR=./factories
# AGNI_KATEX_DIR=./katex
# AGNI_SERVE_DIR=./serve

# ── Server Ports ─────────────────────────────────────────────────────────────
# AGNI_THETA_PORT=8082
# AGNI_SERVE_PORT=8080
# AGNI_SENTRY_PORT=8081

# ── CORS ─────────────────────────────────────────────────────────────────────
# Allowed origin for API responses. Defaults to 'null' (deny cross-origin).
# Set to your portal origin (e.g. http://192.168.1.10:5173) or '*' for open hubs.
# AGNI_CORS_ORIGIN=http://192.168.1.10:5173

# ── Hub Identity ─────────────────────────────────────────────────────────────
# AGNI_HUB_ID=hub-local

# ── Governance ───────────────────────────────────────────────────────────────
# AGNI_APPROVED_CATALOG=./data/approved_catalog.json
# AGNI_GOVERNANCE_POLICY=./data/governance_policy.json

# ── Graph / Scheduling Thresholds ────────────────────────────────────────────
# AGNI_MIN_LOCAL_SAMPLE=40
# AGNI_MIN_LOCAL_EDGES=5

# ── LMS Engine Tuning ───────────────────────────────────────────────────────
# AGNI_EMBEDDING_DIM=16
# AGNI_FORGETTING=0.95
# AGNI_EMBEDDING_LR=0.01
# AGNI_EMBEDDING_REG=0.001

# ── Sync / Federation ───────────────────────────────────────────────────────
# AGNI_SYNC_TRANSPORT=starlink
# AGNI_HOME_URL=https://home.example.com
# AGNI_USB_PATH=/mnt/usb/agni-sync

# ── Sentry Analysis ─────────────────────────────────────────────────────────
# AGNI_ANALYSE_AFTER=50
# AGNI_ANALYSE_CRON=02:00

# ── Portal (build-time) ─────────────────────────────────────────────────────
# VITE_HUB_URL=http://192.168.1.10:8082
