{
  "name": "agni-core",
  "version": "0.1.0",
  "description": "AGNI: The compiler and runtime for the Open Lesson Standard (OLS).",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "agni": "./packages/agni-cli/cli.js"
  },
  "keywords": [
    "agni",
    "ols",
    "offline-education",
    "sensor-learning",
    "education",
    "compiler",
    "yaml",
    "lesson-builder",
    "interactive-learning"
  ],
  "author": "AGNI Maintainers",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/NewmanB1/AGNI.git"
  },
  "bugs": {
    "url": "https://github.com/NewmanB1/AGNI/issues"
  },
  "homepage": "https://github.com/NewmanB1/AGNI#readme",
  "engines": {
    "node": ">=14"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "js-yaml": "^4.1.0",
    "katex": "^0.16.33",
    "rehype-katex": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^18.0.0",
    "ajv-cli": "^5.0.0",
    "c8": "^10.1.3",
    "cross-env": "^7.0.3",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.3.0",
    "json-schema-to-typescript": "^15.0.4",
    "mocha": "^10.8.2",
    "nodemon": "^3.1.14",
    "prettier": "^3.0.0",
    "serve": "^14.2.4",
    "typescript": "^5.0.0"
  },
  "scripts": {
    "compile": "node packages/agni-cli/cli.js",
    "build": "node packages/agni-cli/cli.js lessons/gravity.yaml --format=html --output=dist/gravity.html",
    "build:native": "node packages/agni-cli/cli.js lessons/gravity.yaml --format=native --output-dir=dist/native-gravity",
    "build:all": "npm run build && npm run build:native",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prebuild": "npm run clean",
    "dev": "nodemon --exec \"node packages/agni-cli/cli.js lessons/gravity.yaml --format=html --output=dist/gravity.html\" --watch packages --watch lessons",
    "lint": "eslint hub-tools/ packages/ server/ tests/",
    "lint:fix": "eslint hub-tools/ packages/ server/ tests/ --fix",
    "format": "prettier --write \"hub-tools/**/*.js\" \"packages/**/*.js\" \"server/**/*.js\" \"tests/**/*.js\"",
    "format:check": "prettier --check \"hub-tools/**/*.js\" \"packages/**/*.js\" \"server/**/*.js\" \"tests/**/*.js\"",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.packages.json --noEmit",
    "typecheck:services": "tsc -p tsconfig.services.json --noEmit",
    "typecheck:packages": "tsc -p tsconfig.packages.json --noEmit",
    "init:data": "node scripts/init-data.js",
    "promote:admin": "node scripts/promote-admin.js",
    "validate": "node scripts/validate-all.js",
    "sneakernet": "node scripts/sneakernet.js",
    "test": "mocha tests/unit/*.test.js",
    "test:unit": "mocha tests/unit/*.test.js",
    "test:watch": "mocha --watch tests/unit/*.test.js",
    "test:coverage": "c8 --lines 85 --reporter=text --reporter=lcov mocha tests/unit/*.test.js",
    "test:contract": "node tests/contract-hub-api.js",
    "test:graph": "node tests/graph-verification-test.js",
    "test:e2e": "npx playwright test",
    "test:e2e:dev": "cross-env AGNI_HUB_API_KEY=e2e-test-hub-key npx playwright test",
    "test:integration": "mocha tests/integration/*.test.js",
    "test:all": "mocha tests/unit/*.test.js tests/integration/*.test.js && node tests/contract-hub-api.js && node tests/graph-verification-test.js",
    "validate:lesson": "node packages/ols-schema/lesson-validator.js",
    "codegen:validate-schemas": "node scripts/codegen-validate-schemas.js",
    "codegen:types": "node scripts/codegen-types.js",
    "dev:vite": "npx serve -l 5174 --no-port-switching dist",
    "portal": "cd portal && serve -l 3000",
    "start:hub": "cross-env NODE_OPTIONS=--max-old-space-size=512 node hub-tools/theta.js",
    "start:hub:test": "cross-env AGNI_HUB_API_KEY=e2e-test-hub-key node hub-tools/theta.js",
    "test:es5": "node scripts/check-es5.js",
    "verify:dead-files": "node scripts/check-dead-files.js",
    "verify:dts": "node scripts/check-dts-arity.js",
    "verify:innerhtml": "node scripts/check-innerhtml.js",
    "verify:factory-order": "node scripts/check-factory-order.js",
    "verify:schema-sync": "node scripts/sync-schema-enums.js --check",
    "verify:codegen-sync": "node scripts/check-codegen-sync.js",
    "verify:canonical": "node scripts/verify-canonical-ownership.js",
    "verify:canonical-imports": "node scripts/check-canonical-imports.js",
    "verify:svg-tools": "node scripts/check-svg-tools.js",
    "verify:runtime-manifest": "node scripts/check-runtime-manifest.js",
    "verify:runtime-headers": "node scripts/check-runtime-headers.js",
    "verify:runtime-docs": "node scripts/check-runtime-docs.js",
    "verify:runtime-lint": "eslint packages/agni-runtime/",
    "verify:sensors": "node scripts/check-known-sensors.js",
    "verify:unauthed-routes": "node scripts/check-unauthed-routes.js",
    "verify:version-sync": "node scripts/check-version-sync.js",
    "verify:api-contract-auth": "node scripts/check-api-contract-auth.js",
    "verify:hub-imports": "node scripts/check-hub-imports.js",
    "verify:hub-docs": "node scripts/check-hub-docs.js",
    "verify:services-no-scripts": "node scripts/check-services-no-scripts.js",
    "verify:services-test-targets": "node scripts/check-services-test-targets.js",
    "verify:services-docs": "node scripts/check-services-docs.js",
    "verify:services-lint": "eslint packages/agni-services/",
    "verify:hub-no-scripts": "node scripts/check-hub-no-scripts.js",
    "verify:hub-test-targets": "node scripts/check-hub-test-targets.js",
    "verify:hub-lint": "eslint packages/agni-hub/",
    "verify:config-injection": "mocha --config .mocharc.verify.json tests/unit/config-injection.test.js",
    "verify:precache-regression": "node scripts/check-precache-regression.js",
    "verify:governance-canonical": "node scripts/check-governance-canonical.js",
    "verify:governance-docs": "node scripts/check-governance-docs.js",
    "verify:governance-paths": "node scripts/check-governance-paths.js",
    "verify:node-version-docs": "node scripts/check-node-version-docs.js",
    "verify:engine-no-ts": "node scripts/check-engine-no-ts.js",
    "verify:package-headers": "node scripts/check-package-headers.js",
    "verify:hub-config-pi": "node scripts/check-hub-config-pi.js",
    "verify:hub-config-bootstrap": "node scripts/check-hub-config-bootstrap.js",
    "verify:skill-dag": "node scripts/check-skill-dag.js",
    "verify:catalog-ir-consistency": "node scripts/check-catalog-ir-consistency.js",
    "verify:architectural-remediation": "mocha --config .mocharc.verify.json tests/unit/architectural-remediation-verification.test.js",
    "verify:run-environments": "node scripts/check-run-environments.js",
    "verify:governance": "node scripts/check-governance-canonical.js && node scripts/check-governance-docs.js && node scripts/check-governance-paths.js && mocha --config .mocharc.verify.json tests/unit/governance.test.js",
    "verify:core": "npm run verify:dead-files --silent && npm run verify:dts --silent && npm run verify:innerhtml --silent && npm run verify:factory-order --silent && npm run verify:precache-regression --silent && npm run verify:schema-sync --silent && npm run verify:codegen-sync --silent && npm run verify:canonical --silent && npm run verify:canonical-imports --silent && npm run verify:node-version-docs --silent && npm run verify:engine-no-ts --silent && npm run verify:package-headers --silent && npm run verify:skill-dag --silent && npm run verify:run-environments --silent && npm run verify:architectural-remediation --silent && npm run test:es5 --silent",
    "verify:runtime": "npm run verify:svg-tools --silent && npm run verify:runtime-manifest --silent && npm run verify:runtime-headers --silent && npm run verify:runtime-docs --silent && npm run verify:runtime-lint --silent && npm run verify:sensors --silent",
    "verify:hub": "npm run verify:hub-config-pi --silent && npm run verify:hub-config-bootstrap --silent && npm run verify:unauthed-routes --silent && npm run verify:version-sync --silent && npm run verify:api-contract-auth --silent && npm run verify:hub-imports --silent && npm run verify:hub-no-scripts --silent && npm run verify:hub-test-targets --silent && npm run verify:hub-docs --silent && npm run verify:hub-lint --silent && npm run verify:config-injection --silent && npm run verify:catalog-ir-consistency --silent && npm run verify:theta-api --silent",
    "verify:services": "npm run verify:services-no-scripts --silent && npm run verify:services-test-targets --silent && npm run verify:services-docs --silent && npm run verify:services-lint --silent",
    "verify:theta-api": "mocha --config .mocharc.verify.json tests/unit/theta-api.test.js",
    "verify:all": "npm run verify:core --silent && npm run verify:runtime --silent && npm run verify:hub --silent && npm run verify:services --silent && npm run verify:governance --silent"
  }
}
