{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agni-project.org/schemas/groups.schema.json",
  "title": "AGNI Student Groups",
  "description": "Named groups of students for collaborative lesson assignment and cohort tracking.",
  "type": "object",
  "required": ["groups"],
  "additionalProperties": false,
  "properties": {
    "groups": {
      "type": "array",
      "description": "List of student groups.",
      "items": {
        "type": "object",
        "required": ["id", "name", "studentIds"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique group identifier."
          },
          "name": {
            "type": "string",
            "description": "Human-readable group name."
          },
          "studentIds": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Pseudo-IDs of students belonging to this group."
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp when the group was created."
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp when the group was last modified."
          }
        }
      }
    }
  }
}
